pipeline {
    agent any

    options {
        // 保留最近30次构建记录
        buildDiscarder(logRotator(numToKeepStr: '30'))
        // 超时时间（分钟）
        timeout(time: 60, unit: 'MINUTES')
        // 禁止并发构建
        disableConcurrentBuilds()
        // 时间戳
        timestamps()
    }

    environment {
        // Python 环境
        PYTHON_VERSION = '3.11'
        VENV_DIR = "${WORKSPACE}/venv"

        // 测试环境配置
        APP_ENV = 'test'
        BROWSER_TYPE = 'chromium'
        BROWSER_HEADLESS = 'true'

        // 报告路径
        REPORTS_DIR = "${WORKSPACE}/reports"
        ALLURE_REPORT_DIR = "${REPORTS_DIR}/allure"
        HTML_REPORT_DIR = "${REPORTS_DIR}/html"

        // 测试标记（可参数化）
        PYTEST_MARKERS = 'smoke or regression'
    }

    parameters {
        choice(
            name: 'BROWSER',
            choices: ['chromium', 'firefox', 'webkit'],
            description: '选择浏览器类型'
        )
        choice(
            name: 'ENVIRONMENT',
            choices: ['dev', 'test', 'staging'],
            description: '选择测试环境'
        )
        booleanParam(
            name: 'RUN_SLOW_TESTS',
            defaultValue: false,
            description: '是否运行慢速测试'
        )
        booleanParam(
            name: 'HEADED_MODE',
            defaultValue: false,
            description: '是否使用有头模式（调试用）'
        )
        string(
            name: 'PYTEST_ARGS',
            defaultValue: '',
            description: '额外的 pytest 参数'
        )
    }

    stages {
        stage('Preparation') {
            steps {
                script {
                    echo "========================================="
                    echo "  Web Automation Test Pipeline"
                    echo "========================================="
                    echo "Environment: ${params.ENVIRONMENT}"
                    echo "Browser: ${params.BROWSER}"
                    echo "Workspace: ${WORKSPACE}"
                    echo "Build Number: ${BUILD_NUMBER}"
                    echo "========================================="
                }

                // 清理工作空间（可选）
                cleanWs(
                    deleteDirs: true,
                    patterns: [
                        [pattern: 'reports/**', type: 'INCLUDE'],
                        [pattern: 'logs/**', type: 'INCLUDE'],
                        [pattern: '**/__pycache__', type: 'INCLUDE']
                    ]
                )
            }
        }

        stage('Checkout') {
            steps {
                script {
                    echo "Checking out source code..."
                }

                // 检出代码
                checkout scm

                // 显示Git信息
                sh '''
                    echo "Git Branch: $(git rev-parse --abbrev-ref HEAD)"
                    echo "Git Commit: $(git rev-parse HEAD)"
                '''
            }
        }

        stage('Setup Environment') {
            steps {
                script {
                    echo "Setting up Python environment..."

                    // 检查 Python 是否安装
                    sh """
                        python3 --version || python --version
                    """

                    // 创建虚拟环境
                    sh """
                        if [ ! -d "${VENV_DIR}" ]; then
                            echo "Creating virtual environment..."
                            python3 -m venv "${VENV_DIR}" || python -m venv "${VENV_DIR}"
                        else
                            echo "Virtual environment already exists"
                        fi
                    """

                    // 激活虚拟环境并升级 pip
                    sh """
                        . "${VENV_DIR}/bin/activate"
                        pip install --upgrade pip setuptools wheel
                    """

                    // 安装依赖
                    sh """
                        . "${VENV_DIR}/bin/activate"
                        pip install -r requirements.txt
                        pip install -r requirements-dev.txt
                    """

                    // 安装 Playwright 浏览器
                    sh """
                        . "${VENV_DIR}/bin/activate"
                        playwright install --with-deps ${params.BROWSER}
                    """

                    // 创建 .env 文件
                    sh """
                        if [ ! -f .env ]; then
                            cp .env.example .env
                            echo "Created .env file from .env.example"
                        fi
                    """
                }
            }
        }

        stage('Run Tests') {
            steps {
                script {
                    echo "Running tests..."

                    // 构建测试命令
                    def pytest_cmd = """
                        . "${VENV_DIR}/bin/activate"
                        pytest tests/ \
                            --browser=${params.BROWSER} \
                            --base-url=\${APP_BASE_URL} \
                            --headed=${params.HEADED_MODE} \
                            -v \
                            --tb=short \
                            --html=${HTML_REPORT_DIR}/report.html \
                            --self-contained-html \
                            --alluredir=${ALLURE_REPORT_DIR} \
                            --junitxml=${REPORTS_DIR}/junit/results.xml \
                            -m "${PYTEST_MARKERS}"
                    """

                    // 添加慢速测试选项
                    if (params.RUN_SLOW_TESTS) {
                        pytest_cmd += " --slow"
                    }

                    // 添加额外的 pytest 参数
                    if (params.PYTEST_ARGS) {
                        pytest_cmd += " ${params.PYTEST_ARGS}"
                    }

                    // 执行测试
                    sh """
                        mkdir -p ${REPORTS_DIR}/html
                        mkdir -p ${REPORTS_DIR}/allure
                        mkdir -p ${REPORTS_DIR}/junit

                        ${pytest_cmd}
                    """
                }
            }
        }

        stage('Generate Reports') {
            steps {
                script {
                    echo "Generating test reports..."

                    // 生成 Allure 报告
                    script {
                        try {
                            allure([
                                includeProperties: false,
                                jdk: '',
                                reportBuildPolicy: 'ALWAYS',
                                reportSites: [[
                                    alwaysLinkToLastBuild: true,
                                    keepAll: true,
                                    reportFiles: 'allure-report'
                                ]]
                            ])
                        } catch (Exception e) {
                            echo "Allure report generation failed: ${e.message}"
                        }
                    }
                }
            }
        }

        stage('Publish Results') {
            steps {
                script {
                    echo "Publishing test results..."

                    // 发布 JUnit 测试结果
                    junit testResults: 'reports/junit/*.xml',
                          allowEmptyResults: true,
                          skipPublishingChecks: true

                    // 发布 HTML 报告
                    publishHTML([
                        allowMissing: true,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'reports/html',
                        reportFiles: 'report.html',
                        reportName: 'Test Report',
                        reportTitles: 'Automation Test Report'
                    ])

                    // 归档测试产物
                    archiveArtifacts(
                        artifacts: 'reports/**/*.png,reports/**/*.webm,reports/**/*.html,logs/**/*.log',
                        allowEmptyArchive: true,
                        fingerprint: true
                    )
                }
            }
        }

        stage('Notifications') {
            steps {
                script {
                    echo "Sending notifications..."

                    // 发送钉钉通知（如果配置了）
                    // sh """
                    //     . "${VENV_DIR}/bin/activate"
                    //     python jenkins/scripts/send_notification.py
                    // """

                    // 发送邮件通知（如果配置了）
                    // emailext(
                    //     subject: "Test Report - Build #${BUILD_NUMBER} - ${currentBuild.result}",
                    //     body: """
                    //         <h2>Build Summary</h2>
                    //         <p><strong>Build Number:</strong> ${BUILD_NUMBER}</p>
                    //         <p><strong>Status:</strong> ${currentBuild.result}</p>
                    //         <p><strong>Duration:</strong> ${currentBuild.durationString}</p>
                    //         <p>View full report: <a href="${BUILD_URL}">${BUILD_URL}</a></p>
                    //     """,
                    //     to: "${EMAIL_RECIPIENTS}",
                    //     mimeType: 'text/html'
                    // )
                }
            }
        }
    }

    post {
        always {
            script {
                echo "Pipeline execution completed."

                // 清理虚拟环境（可选）
                // sh """
                //     rm -rf "${VENV_DIR}"
                // """
            }
        }

        success {
            script {
                echo "✅ Tests passed successfully!"

                // 更新构建描述
                currentBuild.description = """
                    <span style="color: green;">✓ PASSED</span><br/>
                    Browser: ${params.BROWSER}<br/>
                    Environment: ${params.ENVIRONMENT}
                """.stripIndent()
            }
        }

        failure {
            script {
                echo "❌ Tests failed!"

                // 更新构建描述
                currentBuild.description = """
                    <span style="color: red;">✗ FAILED</span><br/>
                    Browser: ${params.BROWSER}<br/>
                    Environment: ${params.ENVIRONMENT}
                """.stripIndent()

                // 发送失败通知
                // sh """
                //     . "${VENV_DIR}/bin/activate"
                //     python jenkins/scripts/send_notification.py --status failed
                // """
            }
        }

        unstable {
            script {
                echo "⚠️ Tests unstable!"

                currentBuild.description = """
                    <span style="color: orange;">⚠ UNSTABLE</span><br/>
                    Browser: ${params.BROWSER}<br/>
                    Environment: ${params.ENVIRONMENT}
                """.stripIndent()
            }
        }

        cleanup {
            script {
                echo "Cleaning up..."

                // 清理旧的报告（保留最近10次）
                sh """
                    find reports/ -type f -mtime +7 -delete 2>/dev/null || true
                """
            }
        }
    }
}
